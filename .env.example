# ─────────────────────────────────────────────────────────────────────────────
# Quest — environment configuration  ·  runs on GreenNode AgentBase (no own domain)
# Copy to `.env` and fill the secrets:   cp .env.example .env   (keep `.env` out of git)
# (Jun 10) = real value comes from the AgentBase workshop / GreenNode console.
# (TBD)    = exact var name/format to confirm — AgentBase docs aren't public yet.
# ─────────────────────────────────────────────────────────────────────────────

# ── App / server ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Public HTTPS origin of THIS service — YOUR OWN domain (you have one + can set DNS).
# Deploy the service to AgentBase, then point your domain at it: a DNS CNAME → the
# AgentBase service hostname, or Cloudflare in front (free TLS + proxy). This URL is
# both the Zalo webhook target AND the quest/board page base.
# Local dev (before DNS): a cloudflared/ngrok https tunnel to localhost:3000.
BASE_URL=https://quest.yourdomain.com
TZ=Asia/Ho_Chi_Minh            # scheduler + quiet-hours run in Vietnam time
LOG_LEVEL=info

# ── GreenNode AgentBase — runtime / RAG / memory ─────────────────────────────
# The service is DEPLOYED to AgentBase's serverless runtime (micro-VM) → it gives
# back the public URL above. These auth it + point at the built-in RAG & Memory
# (so we don't self-host a vector DB). Exact names TBD at the workshop.
AGENTBASE_API_KEY=REPLACE_ME                                 # (Jun 10)
AGENTBASE_BASE_URL=https://api.agentbase.greennode.ai        # (Jun 10) (TBD)
AGENTBASE_RAG_ID=quest-course-packs                          # RAG Engine knowledge id   (TBD)
AGENTBASE_MEMORY_NS=quest                                    # Memory namespace          (TBD)

# ── GreenNode Serverless AI — models (the MaaS) ──────────────────────────────
# Key from  https://aiplatform.console.greennode.ai/api-keys
GREENNODE_API_KEY=REPLACE_ME                                 # (Jun 10)
GREENNODE_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1   # OpenAI-compatible ✓
# Model ids are HF-style (e.g. "BAAI/bge-m3"). Confirm the exact chat ids on the console:
MODEL_REASONER=minimax/minimax-m2.5        # Tier 1 — reasoning model (thinking ON): plan · diagnose · insight
MODEL_TUTOR=qwen/qwen3-5-27b               # Tier 2 — Qwen, call with thinking OFF: tutor · author · grade · VN
MODEL_GATE=google/gemma-4-31b-it           # Tier 3 — instruct, fast: route · guard · nudge · quick-grade
MODEL_EMBED=baai/bge-m3                     # multilingual embeddings (RAG)
MODEL_RERANK=qwen/qwen3-reranker-8b        # RAG reranker
# MODEL_SAFETY=google/shieldgemma-2-4b     # (optional) safety moderation

# ── Zalo Bot  (see zalo-bot-docs/) ───────────────────────────────────────────
# Create the bot in the Zalo app → OA "Zalo Bot Manager" → Create bot → it DMs the token.
ZALO_BOT_TOKEN=12345689:abc-xyz-REPLACE_ME
ZALO_API_BASE=https://bot-api.zaloplatforms.com             # token goes in the URL path
# A secret YOU choose (8–256 chars). Passed to setWebhook; verify it in the
# `X-Bot-Api-Secret-Token` header on every inbound webhook.
ZALO_WEBHOOK_SECRET=replace-with-a-long-random-string

# ── Relational data — Postgres ───────────────────────────────────────────────
# Classes / members / events / mastery numbers. Use a GreenNode/VNG Cloud managed
# Postgres (or Neon/Supabase). AgentBase Memory holds the unstructured tutor/profile
# memory; this DB holds the structured state. (pgvector only if you self-host RAG.)
DATABASE_URL=postgres://user:pass@host:5432/quest           # (Jun 10)

# ── Auth / temp links ────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string   # signs short-lived quest/board links (no login)
LINK_TTL_SECONDS=86400                          # link validity (24h)
CRON_SECRET=replace-me                          # protects POST /cron/tick?key=...

# ── Optional / stretch ───────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379             # rate-limit / cache (skip for MVP)
# ZALO_AI_STT_KEY=                             # voice in  (stretch)
# ZALO_AI_TTS_KEY=                             # voice out (.aac) (stretch)

# ── Admin / owner ────────────────────────────────────────────────────────────
# Only this Zalo chat id can summon the (signed, short-lived) admin link via the bot.
OWNER_CHAT_ID=
ADMIN_TTL_SECONDS=3600           # admin link lifetime (1h)
QUEST_LINK_TTL_SECONDS=2592000   # quest links stay valid 30d (access still gated server-side)

# Public deep-link to open YOUR bot (shown to learners): zalo.me/<your-bot-id>
ZALO_BOT_URL=http://zalo.me/your-bot

# Marketing domain(s) whose ROOT serves the pitch/voting page (comma-separated). It's also at /pitch.
# PITCH_HOST=quest.gssea.space
